# Copy this file to .streamlit/secrets.toml for local use,
# OR paste these key-value pairs into the Streamlit Cloud secrets UI.

SNOWFLAKE_ACCOUNT  = "your_account_identifier"   # e.g. xy12345.us-east-1
SNOWFLAKE_USER     = "your_username"
SNOWFLAKE_PASSWORD = "your_password"
SNOWFLAKE_DATABASE = "US_OPEN_CENSUS_DATA__NEIGHBORHOOD_INSIGHTS__FREE_DATASET"
SNOWFLAKE_SCHEMA   = "PUBLIC"
SNOWFLAKE_WAREHOUSE = "COMPUTE_WH"
SNOWFLAKE_ROLE     = "ACCOUNTADMIN"

OPENROUTER_API_KEY = "sk-or-v1-..."

# Optional
LOG_LEVEL = "INFO"
