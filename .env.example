# Snowflake credentials
SNOWFLAKE_ACCOUNT=your_account_identifier         # e.g. xy12345.us-east-1
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_DATABASE=GLOBAL_GOVERNMENT              # Snowflake Marketplace: US Census dataset DB
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=ACCOUNTADMIN

# OpenRouter API key (model: meta-llama/llama-3.3-70b-instruct:free)
OPENROUTER_API_KEY=your_openrouter_api_key

# Optional: adjust logging verbosity
LOG_LEVEL=INFO
